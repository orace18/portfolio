rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Dossier "covers/" : lecture publique (images des projets), écriture
    // réservée aux utilisateurs authentifiés, limitée aux images de 2 Mo max.
    match /covers/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Par défaut, tout le reste est fermé.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
