# Copiez ce fichier en .env et renseignez vos vraies valeurs. Ne jamais committer .env.

# Connection string MongoDB (Atlas ou autre)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/portfolio

# Secret utilisé pour signer les JWT — générez une longue chaîne aléatoire
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Utilisés uniquement par `npm run seed:admin` pour créer/mettre à jour le compte admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Port d'écoute de l'API
PORT=3000

# Origines autorisées en CORS (séparées par des virgules)
CORS_ORIGIN=http://localhost:4200
