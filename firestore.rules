rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Collection "projects" : lecture publique, écriture réservée aux
    // utilisateurs authentifiés (le compte admin créé dans la console Firebase).
    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Par défaut, tout le reste est fermé.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
